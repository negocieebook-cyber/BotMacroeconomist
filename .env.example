# Variaveis de ambiente para BotMacroeconomist

# FRED API
# Obtenha em: https://fred.stlouisfed.org/docs/api
FRED_API_KEY=seu_fred_api_key_aqui

# OpenAI API (opcional)
# OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_LLM_TEMPERATURE=0.2

# OpenRouter API (opcional; prioritaria para chat/tese quando configurada)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=BotMacroeconomist

# X / social listening
# Padrao recomendado: disabled. O projeto funciona com RSS, sites e inputs manuais.
# Use api apenas se um dia voce tiver acesso pago/valido ao endpoint do X.
X_COLLECTION_MODE=disabled
X_ALLOW_MOCK_FALLBACK=False
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=
X_API_BASE=https://api.x.com/2
X_POST_FETCH_LIMIT=5
X_REQUEST_TIMEOUT=20

# Telegram (opcional)
# 1. Coloque o token do bot
# 2. Fale com seu bot no Telegram
# 3. Rode: python main.py telegram-chat-id
# 4. Copie o chat id encontrado para baixo
# 5. Rode: python main.py telegram-listen para ele responder perguntas por la
# Se nao quiser trafego de rede para Telegram, mantenha ENABLE_TELEGRAM_NOTIFICATIONS=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM_NOTIFICATIONS=False

# Pesquisa e tese diaria (opcional)
DAILY_RESEARCH_HOUR_UTC=12
DAILY_RESEARCH_MINUTE_UTC=0
DAILY_THESIS_HOUR_UTC=18
DAILY_THESIS_MINUTE_UTC=0
DAILY_THESIS_TOPIC=inflacao, juros reais, crescimento, fiscal e risco financeiro
RESEARCH_FEED_LIMIT=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/macroeconomist.log

# ChromaDB
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=macroeconomic_data

# Timezone
TIMEZONE=UTC

# Debug
DEBUG=False
