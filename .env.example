# Variaveis de ambiente para BotMacroeconomist

# FRED API
# Obtenha em: https://fred.stlouisfed.org/docs/api
FRED_API_KEY=seu_fred_api_key_aqui

# OpenAI API (opcional)
# OPENAI_API_KEY=sk-...

# Telegram (opcional)
# 1. Coloque o token do bot
# 2. Fale com seu bot no Telegram
# 3. Rode: python main.py telegram-chat-id
# 4. Copie o chat id encontrado para baixo
# 5. Rode: python main.py telegram-listen para ele responder perguntas por la
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM_NOTIFICATIONS=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/macroeconomist.log

# ChromaDB
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=macroeconomic_data

# Timezone
TIMEZONE=UTC

# Debug
DEBUG=False
